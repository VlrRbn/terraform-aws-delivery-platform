aws_region   = "eu-west-1"
project_name = "delivery-platform-stage"
environment  = "stage"

vpc_cidr             = "10.30.0.0/16"
public_subnet_cidrs  = ["10.30.1.0/24", "10.30.2.0/24"]
private_subnet_cidrs = ["10.30.11.0/24", "10.30.12.0/24"]

enable_web_ssm = true

web_ami_id       = "ami-REPLACE_WITH_WEB_AMI"
ssm_proxy_ami_id = "ami-REPLACE_WITH_SSM_PROXY_AMI"

web_min_size         = 2
web_desired_capacity = 2
web_max_size         = 3

asg_min_healthy_percentage     = 50
asg_instance_warmup_seconds    = 120
asg_checkpoint_delay_seconds   = 360
tg_slow_start_seconds          = 60
health_check_healthy_threshold = 2
enable_alb_deletion_protection = false
instance_type_web              = "t3.micro"

tf_state_key = "delivery-platform/stage/full/terraform.tfstate"

demo_api_token_parameter_name = "/devops/delivery-platform/stage/demo/api-token"
demo_app_secret_name          = "/devops/delivery-platform/stage/demo/app-secret"

common_tags = {
  Owner       = "PlatformTeam"
  Criticality = "medium"
}
