aws_region = "eu-west-1"

project_name = "delivery-platform-audit"
trail_name   = "delivery-platform-audit-terraform-audit-trail"

# Must be globally unique. Include your short name/account/region.
cloudtrail_log_bucket_name = "YOURNAME-cloudtrail-logs-ACCOUNTID-eu-west-1"

# Existing Terraform state bucket/prefix from terraform delivery platform.
terraform_state_bucket_name = "YOURNAME-tfstate-ACCOUNTID-eu-west-1"
terraform_state_prefixes = {
  dev   = "delivery-platform/dev/full/"
  stage = "delivery-platform/stage/full/"
  prod  = "delivery-platform/prod/full/"
}

# Lab defaults: focused data events, single region, 30-day retention.
enable_state_data_events = true
is_multi_region_trail    = false
log_retention_days       = 30

# Keep false unless you intentionally want terraform destroy to remove log objects too.
force_destroy_log_bucket = false

common_tags = {
  Owner       = "PlatformTeam"
  ManagedBy  = "Terraform"
  Visibility = "private"
}
